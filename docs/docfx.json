{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "src/Touchstone.Parser/Touchstone.Parser.csproj"
          ],
          "src": ".."
        }
      ],
      "dest": "api",
      "disableDefaultFilter": false,
      "properties": {
        "TargetFramework": "net6.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "*.md",
          "toc.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appTitle": "Touchstone.Parser Documentation",
      "_appFooter": "<span>Copyright © 2026 <a href='https://suryaraj.com'>Surya Raj</a></span>",
      "_enableSearch": true
    }
  }
}
